{
	"compilerOptions": {
		"target": "ES6",
		"module": "CommonJS",
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"baseUrl": "./src",
		"paths": {
			"@config/*": ["config/*"],
			"@utils/*": ["utils/*"],
			"@services/*": ["services/*"],
			"@graphql/*": ["graphql/*"]
		}
	},
	"include": ["src", "src/tests"],
	"exclude": ["node_modules", "dist"]
}
